# Frontend (Vite)
# Copy this file to .env for local dev and set the values.
# Any variable prefixed with VITE_ is public in the browser.
# Never put service_role keys or provider private keys in frontend env.

# API endpoints
VITE_API_BASE_URL=https://your-backend.onrender.com
# Legacy/fallback names used in some files
VITE_API_URL=https://your-backend.onrender.com
VITE_API_BASE=https://your-backend.onrender.com
VITE_DEV_BACKEND=http://localhost:5000

# Public frontend URL used for shareable product links
# Example: https://your-frontend-domain.com
VITE_PUBLIC_WEB_URL=

# Android deep link scheme/package for shareable product URLs
VITE_ANDROID_APP_PACKAGE=com.validele.app
VITE_ANDROID_APP_SCHEME=validel
# Optional: direct App Store URL used by iPhone install button
# Example: https://apps.apple.com/app/id1234567890
VITE_IOS_APP_STORE_URL=

# Supabase client (public anon key only)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>
# Legacy fallback used by the codebase
# VITE_SUPABASE_KEY=<your-supabase-anon-key>

# Admin frontend flags
VITE_ADMIN_USER_ID=<admin-profile-uuid>
VITE_ADMIN_ONLY_MODE=false

# PayDunya frontend mode
VITE_PAYDUNYA_MODE=prod

# Leave these empty on frontend unless you intentionally expose them.
# Prefer handling payment secrets on backend only.
VITE_PAYDUNYA_MASTER_KEY=
VITE_PAYDUNYA_PRIVATE_KEY=
VITE_PAYDUNYA_TOKEN=