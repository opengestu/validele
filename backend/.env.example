# Backend (Node/Express on Render)
# Copy this file to backend/.env locally or define vars in Render dashboard.
# Do not commit real secrets.

# Runtime
NODE_ENV=production
PORT=5000
INTERNAL_BASE_URL=http://localhost:5000

# CORS allow-list origin (set to your Cloudflare Pages URL in production)
VITE_DEV_ORIGIN=https://your-project.pages.dev
# Additional allowed frontend origins (comma-separated, no spaces)
# Example: https://your-project.pages.dev,https://validele.numacademy110.workers.dev
CORS_ALLOWED_ORIGINS=

# Supabase
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>
SUPABASE_ANON_KEY=<your-supabase-anon-key>
# Legacy fallback names used by parts of the codebase
# SUPABASE_KEY=<your-supabase-anon-key>
# SUPABASE_CLIENT_KEY=<your-supabase-anon-key>
# VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>
# VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Auth
JWT_SECRET=<long-random-secret>
ADMIN_JWT_SECRET=<another-long-random-secret>
ADMIN_USER_ID=<admin-profile-uuid>
ADMIN_TOKEN_TTL=3600

# Direct7 SMS
DIRECT7_API_KEY=<direct7-api-key>
D7_API_KEY_NOTIFY=<direct7-notify-api-key>
D7_SMS_URL=https://api.d7networks.com/messages/v1/send

# Firebase push
FIREBASE_PROJECT_ID=validel-d7c83
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_BASE64=

# PayDunya
PAYDUNYA_MODE=prod
PAYDUNYA_MASTER_KEY=<paydunya-master-key>
PAYDUNYA_PRIVATE_KEY=<paydunya-private-key>
PAYDUNYA_PUBLIC_KEY=<paydunya-public-key>
PAYDUNYA_TOKEN=<paydunya-token>
PAYDUNYA_CANCEL_URL=https://your-frontend.domain/payment/cancel
PAYDUNYA_RETURN_URL=https://your-frontend.domain/payment/success
PAYDUNYA_CALLBACK_URL=https://your-backend.onrender.com/api/paydunya/callback

# PixPay / Orange / Wave
PIXPAY_API_KEY=<pixpay-api-key>
PIXPAY_BUSINESS_ID=<pixpay-business-id>
PIXPAY_SERVICE_ID_CLIENT_PAYMENT=213
PIXPAY_SERVICE_ID_VENDOR_PAYOUT=214
PIXPAY_BASE_URL=https://proxy-coreapi.pixelinnov.net/api_v1
PIXPAY_IPN_BASE_URL=https://your-backend.onrender.com
PIXPAY_WAVE_SERVICE_ID=79
PIXPAY_WAVE_BUSINESS_NAME_ID=<pixpay-wave-business-name-id>
PIXPAY_WAVE_REDIRECT_URL=https://your-frontend.domain/payment-success
PIXPAY_WAVE_REDIRECT_ERROR_URL=https://your-frontend.domain/payment-error

# Update checker endpoint
APP_LATEST_VERSION=1.0.0
# Optional aliases accepted by code:
# LATEST_APP_VERSION=1.0.0
# ANDROID_LATEST_VERSION=1.0.0
FORCE_APP_UPDATE=false
APP_UPDATE_MESSAGE=A new app version is available.

# Schedulers and reconcilers
ENABLE_PAYOUT_SCHEDULER=false
PAYOUT_SCHEDULE_CRON=0 2 * * *
ENABLE_PAYMENT_RECONCILER=false
PAYMENT_RECONCILE_CRON=*/5 * * * *
PAYMENT_RECONCILE_MINUTES=15
PAYMENT_RECONCILE_FORCE=false

# PIN protection tuning
PIN_MAX_ATTEMPTS=5
PIN_ATTEMPT_WINDOW_MS=300000
PIN_LOCK_MS=900000

# OTP protection tuning
OTP_SEND_MAX_ATTEMPTS=3
OTP_SEND_WINDOW_MS=600000
OTP_VERIFY_MAX_ATTEMPTS=5
OTP_VERIFY_WINDOW_MS=600000
OTP_LOCK_MS=900000

# Debug flags
DEBUG=false
DEBUG_PIXPAY=false

# Optional test-only variables
TEST_FCM_TOKEN=
ADMIN_URL=http://localhost:5000
API_URL=http://localhost:3000
ADMIN_TOKEN=
ADMIN_PROFILE_ID=
ADMIN_PIN=
ORDER_ID=
